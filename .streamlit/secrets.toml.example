# .streamlit/secrets.toml.example
# ────────────────────────────────────────────────────────────
# Copy this file's contents into Streamlit Cloud →
#   App settings → Secrets → paste and fill in your values.
#
# DO NOT commit the real secrets.toml — it is in .gitignore.
# ────────────────────────────────────────────────────────────

# ── LLM & Search ──────────────────────────────────────────────
GROQ_API_KEY    = "gsk_xxxxxxxxxxxxxxxxxxxx"
TAVILY_API_KEY  = "tvly-xxxxxxxxxxxxxxxxxxxx"

# ── Vector DB (Qdrant Cloud) ───────────────────────────────────
# Leave QDRANT_URL as the default for in-memory mode (no persistence).
# For persistent storage, create a free cluster at cloud.qdrant.io
QDRANT_URL      = "https://your-cluster.qdrant.io"
QDRANT_API_KEY  = "your-qdrant-api-key"

# ── Document store (MongoDB Atlas) ────────────────────────────
# Optional — used to persist session history.
# If omitted, sessions are kept in memory only.
MONGO_URI       = "mongodb+srv://user:pass@cluster.mongodb.net/adaptive_rag"

# ── Internal backend URL ──────────────────────────────────────
# Leave this as localhost — the backend runs in the same process.
API_URL         = "http://localhost:8080"
