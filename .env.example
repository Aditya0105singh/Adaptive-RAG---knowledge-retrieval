# Groq API key — get free key at https://console.groq.com
GROQ_API_KEY=gsk_...

# Groq model to use (llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768)
GROQ_MODEL=llama-3.3-70b-versatile

# Local embedding model (no API key needed — runs on CPU via sentence-transformers)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIM=384

# Qdrant vector database URL (e.g. http://localhost:6333 or Qdrant Cloud URL)
QDRANT_URL=http://localhost:6333

# Qdrant API key (leave empty for local unauthenticated instances)
QDRANT_API_KEY=

# MongoDB connection string for chat history storage
MONGO_URI=mongodb://localhost:27017

# Tavily API key for web search fallback (get free key at https://tavily.com)
TAVILY_API_KEY=tvly-dev-...

# Qdrant collection name for document vectors
QDRANT_COLLECTION=documents
PARENT_CHUNK_SIZE=1500
CHILD_CHUNK_SIZE=400
RELEVANCE_THRESHOLD=0.6
MAX_LOOP_COUNT=2
LOG_LEVEL=INFO
