# Groq API key — get free key at https://console.groq.com
GROQ_API_KEY=gsk_...

# Optional: rotation pool for the evaluation suite. Comma-separated Groq keys
# from DIFFERENT accounts (Groq meters per-organization, so multiple keys on the
# same account share one quota). The eval scripts probe these in order and use
# the first key that still has daily budget. Leave empty to just use GROQ_API_KEY.
GROQ_API_KEYS=

# Groq model to use (llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768)
GROQ_MODEL=llama-3.3-70b-versatile

# Local embedding model (no API key needed — runs on CPU via sentence-transformers)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIM=384

# Qdrant vector database URL (e.g. http://localhost:6333 or Qdrant Cloud URL)
QDRANT_URL=http://localhost:6333

# Qdrant API key (leave empty for local unauthenticated instances)
QDRANT_API_KEY=

# MongoDB connection string for chat history storage
MONGO_URI=mongodb://localhost:27017

# Tavily API key for web search fallback (get free key at https://tavily.com)
TAVILY_API_KEY=tvly-dev-...

# Cohere API key for embeddings (get a free key at https://dashboard.cohere.com)
COHERE_API_KEY=

# Qdrant collection name for document vectors
QDRANT_COLLECTION=documents
PARENT_CHUNK_SIZE=1500
CHILD_CHUNK_SIZE=400
RELEVANCE_THRESHOLD=0.6
MAX_LOOP_COUNT=2
LOG_LEVEL=INFO

# Authentication — set ENABLE_AUTH=true in production and send the key in the
# X-API-Key request header. Left disabled by default for local development.
API_KEY=your-secret-api-key-here
ENABLE_AUTH=false
